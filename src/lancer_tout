import subprocess
import sys
import os
from datetime import datetime

def executer_option(numero):
    """Exécute une option et capture la sortie."""
    fichiers = {
        1: "option1_flux_entropique.py",
        2: "option2_logistique_villani.py",
        3: "option3_waqf_numerique.py"
    }

    print(f"\n{'='*60}")
    print(f"🚀 EXÉCUTION DE L'OPTION {numero}")
    print(f"{'='*60}\n")

    try:
        resultat = subprocess.run(
            [sys.executable, fichiers[numero]],
            capture_output=True,
            text=True,
            check=True
        )
        print(resultat.stdout)
        if resultat.stderr:
            print("⚠️  Erreurs :", resultat.stderr)
        return True
    except subprocess.CalledProcessError as e:
        print(f"❌ Erreur lors de l'exécution de l'option {numero}")
        print(e.stderr)
        return False

